{
  "extends": "stylelint-config-standard-scss",
  "plugins": ["stylelint-declaration-strict-value"],
  "rules": {
    "max-nesting-depth": [4, { "ignore": ["blockless-at-rules", "pseudo-classes"] }],
    "declaration-no-important": [true, { "severity": "warning" }],
    "no-descending-specificity": null,
    "selector-class-pattern": null,
    "selector-id-pattern": null,
    "keyframes-name-pattern": null,
    "color-function-notation": null,
    "color-function-alias-notation": null,
    "alpha-value-notation": null,
    "media-feature-range-notation": null,
    "declaration-block-single-line-max-declarations": null,
    "property-no-vendor-prefix": [true, { "ignoreProperties": ["appearance", "font-smoothing", "backdrop-filter"] }],
    "font-family-name-quotes": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "scss/dollar-variable-pattern": null,
    "scss/at-mixin-pattern": null,
    "scss/percent-placeholder-pattern": null
  },
  "overrides": [
    {
      "files": ["src/scss/**/components/**/*.scss"],
      "rules": {
        "scale-unlimited/declaration-strict-value": [
          ["/color$/", "fill", "stroke"],
          {
            "ignoreValues": ["currentColor", "inherit", "transparent", "none", "initial", "unset"],
            "message": "Цвет только токеном (var(--…) / $token) — см. refactor.md §2 и CLAUDE.md «CSS / SCSS Rules»",
            "severity": "warning"
          }
        ]
      }
    }
  ]
}
